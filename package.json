{
	"name": "monque",
	"private": true,
	"type": "module",
	"author": "Maurice de Bruyn <debruyn.maurice@gmail.com>",
	"license": "ISC",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ueberBrot/monque.git"
	},
	"bugs": {
		"url": "https://github.com/ueberBrot/monque/issues"
	},
	"homepage": "https://github.com/ueberBrot/monque#readme",
	"packageManager": "bun@1.3.11",
	"engines": {
		"node": ">=22.12.0"
	},
	"overrides": {
		"mongodb": "^7.2.0"
	},
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"prepare": "lefthook install",
		"build": "turbo build",
		"type-check": "turbo type-check",
		"test": "turbo test",
		"test:core": "turbo test --filter=@monque/core",
		"test:tsed": "turbo test --filter=@monque/tsed",
		"test:unit": "turbo test:unit",
		"test:unit:core": "turbo test:unit --filter=@monque/core",
		"test:unit:tsed": "turbo test:unit --filter=@monque/tsed",
		"test:integration": "turbo test:integration",
		"test:integration:core": "turbo test:integration --filter=@monque/core",
		"test:integration:tsed": "turbo test:integration --filter=@monque/tsed",
		"test:dev": "turbo test:dev",
		"lint": "biome check .",
		"lint:api-links": "bun scripts/validate-api-links.ts",
		"clean": "turbo clean && rimraf coverage .turbo",
		"clean:core": "turbo clean --filter=@monque/core",
		"clean:tsed": "turbo clean --filter=@monque/tsed",
		"clean:docs": "turbo clean --filter=@monque/docs",
		"clean:dashboard": "turbo clean --filter=@monque/dashboard",
		"clean:dashboard-dev": "turbo clean --filter=@monque/dashboard-dev",
		"dev:docs": "turbo dev --filter=@monque/docs",
		"dev:dashboard": "turbo dev --filter=@monque/dashboard",
		"dev:dashboard-dev": "turbo dev --filter=@monque/dashboard-dev",
		"dev:dashboard-db": "turbo dev:db --filter=@monque/dashboard-dev",
		"build:docs": "turbo build --filter=@monque/docs",
		"build:dashboard": "turbo build --filter=@monque/dashboard",
		"build:dashboard-dev": "turbo build --filter=@monque/dashboard-dev",
		"preview:docs": "turbo preview --filter=@monque/docs",
		"preview:dashboard": "turbo preview --filter=@monque/dashboard",
		"preview:dashboard-dev": "turbo preview --filter=@monque/dashboard-dev",
		"reset": "rimraf --glob '**/node_modules' '**/dist' '**/coverage' '**/.turbo' '**/.astro'",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"check": "biome check --write . && bun run type-check",
		"check:exports": "turbo check:exports",
		"check:unused": "knip",
		"changeset": "changeset",
		"release": "changeset publish",
		"sandcastle": "bun .sandcastle/main.ts"
	},
	"devDependencies": {
		"@ai-hero/sandcastle": "^0.7.0",
		"@arethetypeswrong/cli": "^0.18.3",
		"@biomejs/biome": "^2.4.16",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@types/node": "^22.19.19",
		"knip": "^6.15.0",
		"lefthook": "^2.1.9",
		"publint": "^0.3.21",
		"rimraf": "^6.1.3",
		"turbo": "^2.9.16",
		"typescript": "^6.0.3",
		"unplugin-unused": "^0.5.7",
		"zod": "^4.4.3"
	}
}
