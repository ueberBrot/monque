{
	"name": "@monque/dashboard",
	"version": "0.1.0",
	"description": "Asset-only operator Dashboard for Monque",
	"author": "Maurice de Bruyn <debruyn.maurice@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ueberBrot/monque.git",
		"directory": "packages/dashboard"
	},
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/ueberBrot/monque/issues"
	},
	"homepage": "https://github.com/ueberBrot/monque#readme",
	"sideEffects": [
		"./src/styles.css"
	],
	"type": "module",
	"engines": {
		"node": ">=22.12.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"monque",
		"dashboard",
		"jobs",
		"scheduler",
		"react",
		"tanstack-router"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist",
		"src"
	],
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "tsdown",
		"build:client": "vite build",
		"check:exports": "publint && attw --pack .",
		"clean": "rimraf dist coverage .turbo",
		"preview": "vite preview",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:unit": "bun run type-check && vitest run --coverage.enabled=false",
		"lint": "biome check ."
	},
	"dependencies": {
		"@uiw/react-json-view": "1.12.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@base-ui/react": "^1.5.0",
		"@fontsource-variable/geist": "^5.2.9",
		"@fontsource-variable/geist-mono": "^5.2.8",
		"@monque/management": ">=0.2.1 <0.3.0",
		"@orpc/client": "^1.14.4",
		"@orpc/contract": "^1.14.4",
		"@orpc/openapi-client": "^1.14.4",
		"@orpc/tanstack-query": "^1.14.4",
		"@tanstack/react-form": "^1.33.0",
		"@tanstack/react-form-devtools": "^0.2.29",
		"@tanstack/react-query": "^5.100.14",
		"@tanstack/react-query-devtools": "^5.100.14",
		"@tanstack/react-router": "^1.170.11",
		"@tanstack/react-store": "^0.11.0",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-table-devtools": "^8.21.3",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/devtools-vite": "^0.7.0",
		"@tanstack/react-devtools": "^0.10.5",
		"@tanstack/react-router-devtools": "^1.167.0",
		"@tanstack/router-plugin": "^1.168.14",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^22.19.19",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"jsdom": "^29.1.1",
		"lucide-react": "^1.17.0",
		"publint": "^0.3.21",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"shadcn": "^4.10.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"tailwind-variants": "^3.2.2",
		"tsdown": "^0.22.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
